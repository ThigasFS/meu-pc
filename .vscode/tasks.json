{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Server",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "isBackground": true,
            "presentation": {
                "group": "dev",
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Start Client",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/client"
            },
            "isBackground": true,
            "presentation": {
                "group": "dev",
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Start All (Client & Server)",
            "dependsOn": [
                "Start Server",
                "Start Client"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "group": "dev",
                "panel": "dedicated"
            },
            "runOptions": {
                "reevaluateOnRerun": true
            }
        }
    ]
}